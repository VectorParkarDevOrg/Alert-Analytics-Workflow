# ── Zabbix API ────────────────────────────────────────────────────────────────
# Zabbix 6.4+ uses Bearer token — NOT username/password
# Zabbix UI → top-right menu → API tokens → Create token (no expiry)
ZABBIX_URL=https://your-zabbix-server/api_jsonrpc.php
ZABBIX_TOKEN=your_api_token_here

# Zabbix item display names — must match your Zabbix template exactly
# Run: python test_zabbix.py <hostname> to discover item names on a host
CPU_TOP_ITEM_NAME=Top 5 Processes by CPU Utilization
MEMORY_TOP_ITEM_NAME=Top 5 Processes by Memory Utilization

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Gmail: use an App Password (16 chars) — NOT your login password
# Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Comma-separated list of alert recipients
EMAIL_RECIPIENTS=ops@company.com,alerts@company.com

# ── Microsoft Teams ───────────────────────────────────────────────────────────
# Set TEAMS_ENABLED=true and paste your webhook URL to get in-channel alerts.
#
# Getting the webhook URL — pick ONE method:
#   Option A (Legacy Incoming Webhook, classic Teams):
#     Teams channel → ··· → Connectors → Incoming Webhook → Configure → copy URL
#   Option B (Workflow Connector, new Teams — recommended by Microsoft):
#     Teams channel → Workflows → "Post to a channel when a webhook request is received"
#     → copy the generated HTTPS URL
#
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# ── App ───────────────────────────────────────────────────────────────────────
# SQLite database file path (relative to project root)
DB_PATH=./alert_analytics.db
# Port the service listens on
APP_PORT=6666

# ── Alert Processing ──────────────────────────────────────────────────────────
# Seconds to wait before re-checking Zabbix — alerts resolved within this
# window are silently dropped (no email sent)
ALERT_WAIT_SECONDS=180

# Days of Zabbix history to pull for recurring process detection
HISTORY_DAYS=30

# Max historical snapshots to fetch per alert (Zabbix API limit)
HISTORY_LIMIT=500

# Number of top processes to include in analysis and email report
TOP_PROCESS_COUNT=5
